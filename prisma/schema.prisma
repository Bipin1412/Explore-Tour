generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  CONFIRMED
}

model Booking {
  id               String        @id @default(cuid())
  tripId           String
  tripName         String
  tripPrice        Decimal       @db.Decimal(10, 2)
  fullName         String
  email            String
  phone            String
  travelers        Int
  departureMonth   String
  notes            String?
  paymentStatus    PaymentStatus @default(PENDING)
  paymentRef       String        @unique
  paymentUtr       String?
  paymentConfirmedAt DateTime?
  receiptNumber    String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model AdminTrip {
  id           String   @id
  slug         String   @unique
  name         String
  summary      String   @db.Text
  region       String
  category     String
  destination  String
  durationDays Int
  difficulty   String
  bestMonths   Json
  price        Decimal  @db.Decimal(10, 2)
  heroVideo    String   @db.Text
  heroImage    String   @db.Text
  gallery      Json
  highlights   Json
  itinerary    Json
  overview     String   @db.Text
  inclusions   Json
  exclusions   Json
  faqs         Json
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DeletedTripSlug {
  slug      String   @id
  createdAt DateTime @default(now())
}
